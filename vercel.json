{
    "version": 2,
    "name": "task-management",
    "builds": [
       { "src": "package.json", 
       "use": "vercel-sapper" }
    ],
    "routes": [
       { "src": "/(.*)", "destination": "/index.js" }
    ],
    "rewrites": [
      {
        "src": "/((?!api/.*).*)",
        "dest": "/index.html"
      }
   ]
 }